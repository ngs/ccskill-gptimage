#!/bin/bash
#
# ccskill-gptimage - Image Generation Skill for Claude Code
#
# Usage: ccskill-gptimage <command> [args...]
#
# 自己位置解決ディスパッチャ。~/.local/bin からの symlink で呼ばれても
# readlink で実体位置を辿り、CCSKILL_GPTIMAGE_DIR を解決する。
#

set -e

# Resolve CCSKILL_GPTIMAGE_DIR from this script's location (follow symlinks)
SCRIPT_PATH="$0"
while [ -L "$SCRIPT_PATH" ]; do
    LINK_TARGET=$(readlink "$SCRIPT_PATH")
    case "$LINK_TARGET" in
        /*) SCRIPT_PATH="$LINK_TARGET" ;;
        *)  SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$LINK_TARGET" ;;
    esac
done
CCSKILL_GPTIMAGE_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
export CCSKILL_GPTIMAGE_DIR

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

if [ -f "$CCSKILL_GPTIMAGE_DIR/VERSION" ]; then
    VERSION=$(cat "$CCSKILL_GPTIMAGE_DIR/VERSION")
else
    VERSION=$(cd "$CCSKILL_GPTIMAGE_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
fi

show_help() {
    cat << EOF
ccskill-gptimage - Image Generation Skill for Claude Code (gpt-image-2)

Usage: ccskill-gptimage <command> [args...]

Commands:
  generate <prompt> [options...]   Generate / edit an image (generate_image.py)
  doctor                           Diagnose environment and backends (no secrets read)
  uninstall                        Remove symlinks (~/.local/bin, ~/.claude/skills)
  version                          Show version
  help                             Show this help

Examples:
  ccskill-gptimage generate "a minimalist fox logo, flat vector"
  ccskill-gptimage generate "make the sky golden hour" --reference photo.png
  ccskill-gptimage generate --help

Version: $VERSION
Master:  $CCSKILL_GPTIMAGE_DIR
EOF
}

cmd_generate() {
    PYTHON="$CCSKILL_GPTIMAGE_DIR/venv/bin/python"
    if [ ! -x "$PYTHON" ]; then
        echo -e "${RED}Error: venv not found: $CCSKILL_GPTIMAGE_DIR/venv${NC}" >&2
        echo "" >&2
        echo "Run the installer first:" >&2
        echo "  cd $CCSKILL_GPTIMAGE_DIR && ./install.sh" >&2
        exit 1
    fi
    exec "$PYTHON" "$CCSKILL_GPTIMAGE_DIR/generate_image.py" "$@"
}

# doctor: 環境と backend を診断する。
# 重要: 秘密ファイル(.env / ~/.codex/auth.json)の中身は一切読まない。
# env 変数の有無とファイルの存在のみで判定し、キー値は絶対に出力しない(issue #021)。
cmd_doctor() {
    local ok="${GREEN}✓${NC}" ng="${RED}✗${NC}" warn="${YELLOW}⚠${NC}"
    local hard_fail=0

    echo "ccskill-gptimage doctor"
    echo "Master: $CCSKILL_GPTIMAGE_DIR"
    echo ""

    # --- Environment ---
    echo "Environment:"

    local python="$CCSKILL_GPTIMAGE_DIR/venv/bin/python"
    if [ -x "$python" ] && "$python" -c 'import sys; sys.exit(0 if sys.version_info >= (3, 10) else 1)' 2>/dev/null; then
        local pyver
        pyver="$("$python" -c 'import sys; print(".".join(map(str, sys.version_info[:3])))' 2>/dev/null)"
        echo -e "  $ok Python venv ($pyver)"
    else
        echo -e "  $ng Python venv (>= 3.10)  → cd $CCSKILL_GPTIMAGE_DIR && ./install.sh"
        hard_fail=1
    fi

    if [ -x "$python" ] && "$python" -c 'import openai, dotenv' 2>/dev/null; then
        echo -e "  $ok Dependencies (openai, python-dotenv)"
    else
        echo -e "  $ng Dependencies  → cd $CCSKILL_GPTIMAGE_DIR && ./install.sh"
        hard_fail=1
    fi

    local bin_link="$HOME/.local/bin/ccskill-gptimage"
    if [ -L "$bin_link" ]; then
        echo -e "  $ok Command on PATH ($bin_link)"
    else
        echo -e "  $warn Command symlink missing ($bin_link)  → ./install.sh"
    fi

    case ":$PATH:" in
        *":$HOME/.local/bin:"*) echo -e "  $ok ~/.local/bin is in PATH" ;;
        *) echo -e "  $warn ~/.local/bin not in PATH  → add: export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
    esac

    if [ -f "$HOME/.claude/skills/ccskill-gptimage/SKILL.md" ]; then
        echo -e "  $ok User skill registered (~/.claude/skills/ccskill-gptimage)"
    else
        echo -e "  $warn User skill not registered  → ./install.sh"
    fi

    echo ""

    # --- Backends (presence-based; secrets are NEVER read) ---
    echo "Backends (presence-based; secrets are not read):"

    local codex_ok=0
    if command -v codex > /dev/null 2>&1 && [ -f "$HOME/.codex/auth.json" ]; then
        codex_ok=1
        echo -e "  $ok Codex backend: likely (codex CLI + login session present)"
    elif command -v codex > /dev/null 2>&1; then
        echo -e "  $warn Codex backend: codex CLI present but no login session  → codex login"
    else
        echo -e "  $warn Codex backend: not available  → brew install codex && codex login"
    fi

    local api_ok=0
    if [ -n "${OPENAI_API_KEY:-}" ]; then
        api_ok=1
        echo -e "  $ok API backend: likely (OPENAI_API_KEY set)"
    elif [ -f "$CCSKILL_GPTIMAGE_DIR/.env" ]; then
        api_ok=1
        echo -e "  $ok API backend: likely (.env present; contents not inspected)"
    else
        echo -e "  $warn API backend: not configured  → cp .env.example .env, then set OPENAI_API_KEY"
    fi

    if [ "$codex_ok" -eq 1 ] || [ "$api_ok" -eq 1 ]; then
        echo -e "  $ok At least one backend is configured"
    else
        echo -e "  $ng No backend available — image generation will fail"
        hard_fail=1
    fi

    echo ""
    echo "  Note: backend availability is presence-based. The definitive test is running an"
    echo "  actual generation (ccskill-gptimage generate \"...\")."
    echo ""

    # --- Org Verification (NOT live-checked; see #021) ---
    echo "OpenAI Organization Verification:"
    echo "  If '--backend api' generation returns 403 Forbidden, your Organization is almost"
    echo "  certainly not verified. Complete it at Organization Settings → General → Verification."
    echo "  (doctor cannot detect this without an actual paid generation, so it is not checked.)"
    echo ""

    if [ "$hard_fail" -eq 1 ]; then
        echo -e "${RED}doctor: problems found (see ✗ above).${NC}"
        exit 1
    fi
    echo -e "${GREEN}doctor: ready.${NC}"
    exit 0
}

cmd_uninstall() {
    BIN_LINK="$HOME/.local/bin/ccskill-gptimage"
    SKILL_LINK="$HOME/.claude/skills/ccskill-gptimage"

    if [ -L "$BIN_LINK" ]; then
        /bin/rm -f "$BIN_LINK"
        echo -e "${GREEN}✓ Removed: $BIN_LINK${NC}"
    else
        echo "Not installed (no symlink): $BIN_LINK"
    fi

    if [ -L "$SKILL_LINK" ]; then
        /bin/rm -f "$SKILL_LINK"
        echo -e "${GREEN}✓ Removed: $SKILL_LINK${NC}"
    else
        echo "Not installed (no symlink): $SKILL_LINK"
    fi

    echo ""
    echo "The repository and venv are kept intact: $CCSKILL_GPTIMAGE_DIR"
    echo "To reinstall: cd $CCSKILL_GPTIMAGE_DIR && ./install.sh"
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
    generate)
        cmd_generate "$@"
        ;;
    doctor)
        cmd_doctor "$@"
        ;;
    uninstall)
        cmd_uninstall "$@"
        ;;
    help|--help|-h)
        show_help
        exit 0
        ;;
    version|--version|-v)
        echo "ccskill-gptimage $VERSION"
        exit 0
        ;;
    *)
        echo -e "${RED}Error: Unknown command '$COMMAND'${NC}" >&2
        echo "" >&2
        show_help >&2
        exit 1
        ;;
esac
